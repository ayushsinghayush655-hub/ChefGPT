// TODO: Add your package declaration here if needed (e.g., package com.yourproject;)

import java.util.List;
import java.util.stream.Collectors;

public record Nutrition(int calories, String protein) {}

public record Recipe(
    String id,
    String title,
    List<String> ingredients,
    List<String> steps,
    Nutrition nutrition,
    List<String> tags
) {}

public record FilterOptions(boolean vegOnly, boolean kettleOnly) {}

public class RecipeFilter {

    public static List<Recipe> filterRecipes(List<Recipe> recipes, FilterOptions filters) {
        return recipes.stream()
            .filter(recipe -> {
                List<String> safeTags = recipe.tags().stream()
                    .map(String::toLowerCase)
                    .collect(Collectors.toList());

                // TODO: Change "vegetarian" if your main program uses a different word (like "veg")
                if (filters.vegOnly() && !safeTags.contains("vegetarian")) {
                    return false;
                }

                // TODO: Change "kettle" if your main program uses a different word
                if (filters.kettleOnly() && !safeTags.contains("kettle")) {
                    return false;
                }

                return true;
            })
            .collect(Collectors.toList()); 
    }
}
